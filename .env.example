# Backend only — not used by the frontend. Copy to .env and set for local testing.
# Get a free token at https://huggingface.co/settings/tokens
HUGGING_FACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: API server port (default 3001)
# PORT=3001

# Supabase: frontend (Vite) and server (projects proxy)
# Create a project at https://supabase.com and copy from Settings > API
# Server (npm run server) uses these to proxy project save/load/list so the browser talks to the server, not Supabase (avoids CORS/500).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional: server reads VITE_* above; you can also set SUPABASE_URL and SUPABASE_ANON_KEY for the server only.

# Companion (optional): Railway API URL. When set, controller POSTs state over HTTP so cues show reliably.
# Same URL you use in the Companion module (e.g. https://your-app.up.railway.app)
# VITE_COMPANION_API_URL=https://your-app.up.railway.app
